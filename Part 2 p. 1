output_plot = widgets.Output()

# Define the plotting function
def plot_characteristic_trend(selected_characteristic):
    with output_plot: # Direct output to the output_plot widget
        clear_output(wait=True)

        df_filtered_char = df_merged[df_merged['CharacteristicName'] == selected_characteristic].copy()

        # Convert 'ResultMeasureValue' to numeric, coercing errors to NaN
        df_filtered_char['ResultMeasureValue'] = pd.to_numeric(df_filtered_char['ResultMeasureValue'], errors='coerce')
        # Drop rows where 'ResultMeasureValue' became NaN after conversion
        df_filtered_char.dropna(subset=['ResultMeasureValue'], inplace=True)

        # Sort by date for proper time series plotting
        df_filtered_char.sort_values(by='ActivityStartDate', inplace=True)

        if not df_filtered_char.empty:
            plt.figure(figsize=(15, 8))
            sns.lineplot(
                data=df_filtered_char,
                x='ActivityStartDate',
                y='ResultMeasureValue',
                hue='MonitoringLocationName',
                marker='o',
                palette='tab10'
            )

            # Get unit code safely, handling cases where it might be missing or multiple units exist
            unit_code = ''
            if not df_filtered_char['ResultMeasure/MeasureUnitCode'].empty:
                unit_code = df_filtered_char['ResultMeasure/MeasureUnitCode'].iloc[0]

            plt.title(f'Time Series Trend for {selected_characteristic} at Various Monitoring Locations', fontsize=16)
            plt.xlabel('Activity Start Date', fontsize=12)
            plt.ylabel(f'{selected_characteristic} Result Measure Value ({unit_code})', fontsize=12)
            plt.grid(True, linestyle='--', alpha=0.7)
            plt.xticks(rotation=45, ha='right')
            plt.tight_layout()
